SIIGO_USERNAME=tu_usuario_api@empresa.com
SIIGO_ACCESS_KEY=pega_aqui_tu_access_key
SIIGO_PARTNER_ID=tu_partner_id
SIIGO_BASE_URL=https://api.siigo.com

# Solo si tu tenant o soporte de Siigo te indicó un header adicional para auth.
# SIIGO_AUTHORIZATION_HEADER=Bearer ...

# Solo si tu Python tiene problemas con certificados SSL.
# SIIGO_CA_FILE=/ruta/al/cert.pem

# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=pega_aqui_tu_service_role_key
SUPABASE_SCHEMA=public

# Ventana incremental recomendada.
# Se deja amplia porque el saldo de facturas puede cambiar después de emitidas.
SIIGO_SYNC_LOOKBACK_DAYS=90

# Para backfills o corridas manuales puedes fijar el rango exacto.
# SYNC_FROM_DATE=2026-01-01
# SYNC_TO_DATE=2026-04-30
